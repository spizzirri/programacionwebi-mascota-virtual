{
  "name": "mascota-virtual",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "test": "npm run test --workspaces --if-present",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:e2e": "concurrently \"dotenv -e backend/.e2e-local -- npm run dev:backend\" \"dotenv -e frontend/.e2e-local -- npm run dev:frontend\"",
    "start:e2e:env": "docker compose -f e2e-env/docker-compose.yml up -d",
    "stop:e2e:env": "docker compose -f e2e-env/docker-compose.yml down",
    "test:e2e": "playwright test --config=e2e-tests/playwright.config.ts",
    "db:up": "npm run db:up --workspace=backend",
    "db:down": "npm run db:down --workspace=backend",
    "build:frontend": "npm run build --workspace=frontend",
    "build:backend": "npm run build --workspace=backend",
    "test:frontend": "npm run test --workspace=frontend",
    "test:backend": "npm run test --workspace=backend",
    "type-check": "npm run type-check --workspaces --if-present"
  },
  "dependencies": {
    "concurrently": "^9.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "dotenv-cli": "^11.0.0"
  }
}